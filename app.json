{
  "expo": {
    "name": "World Alert",
    "slug": "world-alert",
    "version": "1.0.1",
    "scheme": "world-alert",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.worldalert.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "World Alert uses your location to show nearby conflict events. Your location is never stored or transmitted beyond the session.",
        "NSLocationAlwaysUsageDescription": "World Alert uses your location to show nearby conflict events. Your location is never stored or transmitted beyond the session."
      },
      "config": {}
    },
    "android": {
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.worldalert.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {}
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ],
      "expo-dev-client",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "World Alert uses your location to show nearby conflict events. Your location is never stored or transmitted beyond the session."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1af8bf84-dfad-4f32-a3bb-b8d96394dc6a"
      }
    }
  }
}
